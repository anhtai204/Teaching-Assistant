# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log

# Chroma Cloud DB (Online Vector Store)
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
CHROMA_API_KEY=your_chroma_api_key_here

# Backend Security
# Generate with: openssl rand -base64 32
INTERNAL_API_KEY=your-strong-random-key-here

# Allowed CORS Origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000

# Default seed accounts (only created when DB is empty)
DEFAULT_LECTURER_EMAIL=lecturer@university.edu
DEFAULT_LECTURER_PASSWORD=change-me
DEFAULT_STUDENT_EMAIL=student@university.edu
DEFAULT_STUDENT_PASSWORD=change-me

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# Auth.js
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
